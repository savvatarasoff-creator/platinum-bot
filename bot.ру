    print(f"Валюты: {', '.join(CURRENCIES.keys())}")
    print("=" * 50)
    
    # Проверяем подключение к боту
    try:
        response = requests.get(f"{BASE_URL}/getMe", timeout=10)
        if response.status_code == 200:
            bot_info = response.json()
            print(f"✅ Бот запущен: @{bot_info['result']['username']}")
            print(f"✅ Ссылка на бота: https://t.me/{bot_info['result']['username']}")
        else:
            print("❌ Ошибка подключения к Telegram")
            return
    except Exception as e:
        print(f"❌ Ошибка подключения: {e}")
        return
    
    offset = 0
    while True:
        try:
            response = requests.get(
                f"{BASE_URL}/getUpdates",
                params={'offset': offset, 'timeout': 30}
            )
            
            if response.status_code == 200:
                updates = response.json().get('result', [])
                
                for update in updates:
                    offset = update['update_id'] + 1
                    
                    if 'message' in update:
                        msg = update['message']
                        user_id = msg['from']['id']
                        
                        db.save_user({
                            'id': user_id,
                            'username': msg['from'].get('username'),
                            'first_name': msg['from'].get('first_name')
                        })
                        
                        if 'photo' in msg:
                            file_id = msg['photo'][-1]['file_id']
                            process_photo(user_id, file_id)
                        
                        elif 'text' in msg:
                            process_text(user_id, msg['text'])
                    
                    elif 'callback_query' in update:
                        callback = update['callback_query']
                        user_id = callback['from']['id']
                        data = callback['data']
                        callback_id = callback['id']
                        
                        db.save_user({
                            'id': user_id,
                            'username': callback['from'].get('username'),
                            'first_name': callback['from'].get('first_name')
                        })
                        
                        handle_callback(user_id, data, callback_id)
        
        except KeyboardInterrupt:
            print("\n🛑 Остановка бота...")
            break
