def process_text(user_id, text):
    state, state_data = db.get_state(user_id)
    
    if not state:
        if text.startswith('/start'):
            args = text.split(' ')[1] if len(text.split(' ')) > 1 else None
            handle_start(user_id, args)
        else:
            send_message(user_id, "👋 Используйте кнопки меню или /start", main_menu(user_id))
        return
    
    if state == 'waiting_amount':
        try:
            amount = float(text.replace(',', '.'))
            if amount < MIN_DEAL_AMOUNT:
                send_message(user_id, f"❌ Минимальная сумма: {MIN_DEAL_AMOUNT}")
                return
            
            state_data['amount'] = amount
            db.save_state(user_id, 'waiting_currency', state_data)
            
            # Если это оплата Stars, сразу создаем сделку
            if state_data.get('payment_method') == 'telegram_stars':
                create_deal_with_currency(user_id, 'TELEGRAM_STARS')
            else:
                send_message(user_id, "💱 <b>Выберите валюту:</b>", currency_keyboard())
        except:
            send_message(user_id, "❌ Неверный формат суммы")
    
    elif state == 'waiting_card':
        if len(text) >= 16 and text.replace(' ', '').isdigit():
            card_number = text.replace(' ', '')
            db.add_payment_method(user_id, 'card', card_number)
            send_message(user_id, "✅ Карта успешно добавлена!", payment_methods_keyboard())
            db.clear_state(user_id)
        else:
            send_message(user_id, "❌ Неверный номер карты")
    
    elif state == 'waiting_ton':
        if len(text) > 30:
            db.add_payment_method(user_id, 'ton', text)
            send_message(user_id, "✅ TON кошелек добавлен!", payment_methods_keyboard())
            db.clear_state(user_id)
        else:
            send_message(user_id, "❌ Неверный адрес TON кошелька")
    
    elif state == 'waiting_deal_id':
        show_deal(user_id, text.upper())
        db.clear_state(user_id)

