def send_message(chat_id, text, keyboard=None, photo_file_id=None):
    if photo_file_id:
        url = f"{BASE_URL}/sendPhoto"
        payload = {
            'chat_id': chat_id,
            'photo': photo_file_id,
            'caption': text,
            'parse_mode': 'HTML'
        }
    else:
        url = f"{BASE_URL}/sendMessage"
        payload = {
            'chat_id': chat_id,
            'text': text,
            'parse_mode': 'HTML'
        }
    
    if keyboard:
        payload['reply_markup'] = json.dumps(keyboard)
    
    try:
        response = requests.post(url, json=payload, timeout=10)
        return response.status_code == 200
    except Exception as e:
        print(f"Ошибка отправки сообщения: {e}")
        return False

def answer_callback(callback_id, text=None):
    url = f"{BASE_URL}/answerCallbackQuery"
    payload = {'callback_query_id': callback_id}
    if text:
        payload['text'] = text
    
    try:
        response = requests.post(url, json=payload, timeout=3)
        return response.status_code == 200
    except:
        return False

def create_invoice_link(title, description, payload, currency, prices, photo_url=None):
    """
    Создание ссылки на инвойс для оплаты через Telegram Stars
    Для Telegram Stars нужно использовать валюту 'XTR'
    """
    url = f"{BASE_URL}/createInvoiceLink"
    
    # Для Telegram Stars используем специальную валюту
    if currency == 'TELEGRAM_STARS':
        currency_code = 'XTR'
    else:
        currency_code = currency
    
    payload_data = {
        'title': title,
        'description': description,
        'payload': payload,
        'currency': currency_code,
        'prices': prices
    }
    
    if photo_url:
        payload_data['photo_url'] = photo_url
    
    try:
        response = requests.post(url, json=payload_data, timeout=10)
        if response.status_code == 200:
            result = response.json()
            if result.get('ok'):
                return result.get('result')
        print(f"Ошибка создания инвойса: {response.text}")
        return None
    except Exception as e:
        print(f"Ошибка создания инвойса: {e}")
        return None

