class Database:
    def __init__(self):
        self.conn = None
        self.connect()
        self.init_db()
    
    def connect(self):
        """Создаем соединение с базой данных"""
        try:
            self.conn = sqlite3.connect('platinum.db', check_same_thread=False, timeout=10)
            self.conn.execute("PRAGMA journal_mode=WAL")  # Включаем режим WAL для лучшей производительности
            print("✅ Подключение к базе данных установлено")
        except Exception as e:
            print(f"❌ Ошибка подключения к базе данных: {e}")
            # Пробуем создать новую базу
            try:
                self.conn = sqlite3.connect('platinum_new.db', check_same_thread=False, timeout=10)
                print("✅ Создана новая база данных")
            except:
                print("❌ Не удалось создать базу данных")
                raise
    
    def init_db(self):
        cursor = self.conn.cursor()
        
        # Создаем таблицу users
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS users (
                user_id INTEGER PRIMARY KEY,
                username TEXT,
                first_name TEXT,
                last_name TEXT,
                is_admin BOOLEAN DEFAULT 0,
                created_at TEXT DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        # Проверяем существование таблицы deals
        cursor.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='deals'")
        if not cursor.fetchone():
            # Создаем таблицу deals с нуля
            cursor.execute('''
                CREATE TABLE deals (
                    id TEXT PRIMARY KEY,
                    seller_id INTEGER NOT NULL,
                    seller_username TEXT NOT NULL,
                    buyer_id INTEGER,
                    buyer_username TEXT,
                    amount REAL NOT NULL,
                    currency TEXT DEFAULT 'RUB',
                    payment_method TEXT,
                    payment_data TEXT,
                    status TEXT DEFAULT 'created',
                    nft_sent BOOLEAN DEFAULT 0,
                    admin_check BOOLEAN DEFAULT 0,
                    check_requested BOOLEAN DEFAULT 0,
                    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
                    expires_at TEXT,
                    completed_at TEXT
                )
            ''')
            print("✅ Таблица deals создана")
        else:
            # Проверяем структуру существующей таблицы
            cursor.execute("PRAGMA table_info(deals)")
            columns = [col[1] for col in cursor.fetchall()]
            
            # Добавляем отсутствующие колонки
            required_columns = ['nft_sent', 'admin_check', 'check_requested', 'completed_at']
            for column in required_columns:
                if column not in columns:
                    try:
                        if column == 'completed_at':
                            cursor.execute(f"ALTER TABLE deals ADD COLUMN {column} TEXT")
                        else:
                            cursor.execute(f"ALTER TABLE deals ADD COLUMN {column} BOOLEAN DEFAULT 0")
                        print(f"✅ Добавлена колонка {column}")
                    except Exception as e:
                        print(f"⚠️ Не удалось добавить колонку {column}: {e}")
        
        # Создаем таблицу payment_methods
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS payment_methods (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER NOT NULL,
                type TEXT NOT NULL,
                data TEXT NOT NULL,
                created_at TEXT DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        # Создаем таблицу user_states
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS user_states (
                user_id INTEGER PRIMARY KEY,
                state TEXT,
                data TEXT
            )
        ''')
        
        self.conn.commit()
        print("✅ База данных инициализирована")
    
    def save_user(self, user_data):
        try:
            cursor = self.conn.cursor()
            # Проверяем если пользователь является администратором
            is_admin = 1 if str(user_data.get('username')).lower() in [admin.lower() for admin in ADMIN_USERNAMES] else 0
            cursor.execute('''
                INSERT OR REPLACE INTO users 
                (user_id, username, first_name, last_name, is_admin)
                VALUES (?, ?, ?, ?, ?)
            ''', (
                user_data['id'],
                user_data.get('username', ''),
                user_data.get('first_name', ''),
                user_data.get('last_name', ''),
                is_admin
            ))
            self.conn.commit()
            return True
        except Exception as e:
            print(f"❌ Ошибка сохранения пользователя: {e}")
            return False
    
    def get_user(self, user_id):
        try:
            cursor = self.conn.cursor()
            cursor.execute("SELECT * FROM users WHERE user_id = ?", (user_id,))
            row = cursor.fetchone()
            if row:
                return {
                    'user_id': row[0],
                    'username': row[1],
                    'first_name': row[2],
                    'last_name': row[3],
                    'is_admin': bool(row[4])
                }
            return None
        except Exception as e:
            print(f"❌ Ошибка получения пользователя: {e}")
            return None
    
    def get_admins(self):
        try:
            cursor = self.conn.cursor()
            cursor.execute("SELECT user_id FROM users WHERE is_admin = 1")
            return [row[0] for row in cursor.fetchall()]
        except Exception as e:
            print(f"❌ Ошибка получения администраторов: {e}")
            # Возвращаем пустой список если нет администраторов в БД
            return []
    
    def has_payment_methods(self, user_id):
        try:
            cursor = self.conn.cursor()
            cursor.execute("SELECT COUNT(*) FROM payment_methods WHERE user_id = ?", (user_id,))
            return cursor.fetchone()[0] > 0
        except Exception as e:
            print(f"❌ Ошибка проверки реквизитов: {e}")
            return False
    
    def get_payment_methods(self, user_id):
        try:
            cursor = self.conn.cursor()
            cursor.execute("SELECT * FROM payment_methods WHERE user_id = ? ORDER BY created_at DESC", (user_id,))
            rows = cursor.fetchall()
            return [{'id': row[0], 'type': row[2], 'data': row[3]} for row in rows]
        except Exception as e:
            print(f"❌ Ошибка получения реквизитов: {e}")
            return []
    
    def add_payment_method(self, user_id, method_type, data):
        try:
            cursor = self.conn.cursor()
            cursor.execute('''
                INSERT INTO payment_methods (user_id, type, data)
                VALUES (?, ?, ?)
            ''', (user_id, method_type, data))
            self.conn.commit()
            return cursor.lastrowid
        except Exception as e:
            print(f"❌ Ошибка добавления реквизита: {e}")
