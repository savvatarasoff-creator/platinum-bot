# Настройка логирования
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(message)s',
    datefmt='%H:%M:%S'
)
logger = logging.getLogger(__name__)

# Хранилище обработанных постов
try:
    with open('goal24_processed.txt', 'r') as f:
        processed_posts = set(int(line.strip()) for line in f)
    print(f"📝 Загружено {len(processed_posts)} ранее обработанных постов")
except FileNotFoundError:
    processed_posts = set()
    print("📝 Новый файл с постами будет создан")

def save_post(post_id):
    """Сохраняет ID поста в файл"""
    with open('goal24_processed.txt', 'a') as f:
        f.write(f"{post_id}\n")

async def main():
    # Создаем клиента
    client = TelegramClient('goal24_session', API_ID, API_HASH)
    
    print("\n" + "="*45)
    print("⚽ БОТ ДЛЯ КАНАЛА @Goal24")
    print("="*45)
    print(f"📱 Номер: {PHONE_NUMBER}")
    print(f"📺 Канал: {CHANNEL_LINK}")
    print(f"💬 Комментарий: '{COMMENT_TEXT}'")
    print("="*45 + "\n")
    
    # Авторизация
    try:
        await client.start(phone=PHONE_NUMBER)
        print("✅ Авторизация успешна!")
    except Exception as e:
        print(f"❌ Ошибка авторизации: {e}")
        print("📝 Проверь номер телефона и код подтверждения")
        return
    
    # Получаем канал
    try:
        channel = await client.get_entity(CHANNEL_LINK)
        print(f"📢 Подключен к каналу: {channel.title}")
        
        # Проверяем последний пост
        last_msg = await client.get_messages(channel, limit=1)
        if last_msg:
            print(f"📌 Последний пост: {last_msg[0].id}")
            if last_msg[0].id in processed_posts:
                print(f"✅ Уже обработан")
            else:
                print(f"🆕 Ожидает комментария")
                
    except Exception as e:
        print(f"❌ Не удалось найти канал: {e}")
        print("💡 Убедись, что канал существует и ты на него подписан")
        return
    
    print("\n🔍 Сканирую последние посты...")
    
    # Проверяем последние 20 постов при старте
    try:
        messages = await client.get_messages(channel, limit=20)
        new_posts = 0
        for msg in messages:
            if msg.id not in processed_posts:
                new_posts += 1
                print(f"  • Пост #{msg.id} - будет прокомментирован")
        print(f"\n📊 Найдено новых постов для комментария: {new_posts}")
    except Exception as e:
        print(f"⚠️ Не удалось получить историю: {e}")
    
    print("\n" + "="*45)
    print("⏳ Бот ЗАПУЩЕН и ждет новые посты!")
    print("📱 Можно свернуть приложение (будет работать в фоне)")
    print("="*45 + "\n")
    
    @client.on(events.NewMessage(chats=channel))
    async def handler(event):
        message = event.message
        msg_id = message.id
        
        # Проверяем, не комментировали ли уже
        if msg_id in processed_posts:
            return
        
        # Информация о посте
        print(f"\n{'='*30}")
        print(f"🆕 НОВЫЙ ПОСТ #{msg_id}")
        if message.text:
            preview = message.text[:50] + "..." if len(message.text) > 50 else message.text
            print(f"📝 Текст: {preview}")
        
        # Случайная задержка (2-6 секунд) - чтобы не спамить
        delay = random.randint(2, 6)
        print(f"⏳ Задержка {delay} сек...")
        await asyncio.sleep(delay)
        
        try:
            # Отправляем комментарий
            await client.send_message(
                entity=channel,
                message=COMMENT_TEXT,
                comment_to=msg_id
            )
            print(f"✅ Комментарий '{COMMENT_TEXT}' оставлен!")
            
            # Сохраняем ID поста
            processed_posts.add(msg_id)
            save_post(msg_id)
            print(f"💾 Пост #{msg_id} сохранен")
            
            # Пауза между комментариями (5-10 секунд)
            if len(processed_posts) % 5 == 0:
                print(f"📊 Всего обработано постов: {len(processed_posts)}")
            
        except Exception as e:
            if "FLOOD" in str(e).upper():
                print(f"⚠️ Telegram просит подождать (flood)")
                await asyncio.sleep(30)
            elif "CHAT_WRITE_FORBIDDEN" in str(e):
                print(f"❌ Нельзя писать комментарии в этом канале")
            else:
                print(f"❌ Ошибка: {e}")
        
        print(f"{'='*30}")
    
    # Держим бота запущенным
    await client.run_until_disconnected()

if __name__ == '__main__':
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\n👋 Бот остановлен")
    except Exception as e:
        print(f"💥 Ошибка: {e}")
        print("\n🔄 Перезапусти бота через 10 секунд...")
        import time
        time.sleep(10)