API_ID = 32680352
API_HASH = 'b2951f1f376d4f6775052c7b9b03ec9a'
PHONE_NUMBER = '+15709935845'  # Новый номер
CHANNEL_LINK = 'https://t.me/Goal24main'  # Канал Goal24

# Настройки
COMMENT_TEXT = 'ого'  # Комментарий
CHECK_INTERVAL = 5  # Проверка каждые 5 секунд

# ============================================
# КОД БОТА (ниже ничего не трогай)
