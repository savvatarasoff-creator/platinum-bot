    def create_deal(self, seller_id, seller_username, amount, currency, payment_method, payment_data):
        try:
            deal_id = f"PL{int(time.time()) % 1000000:06d}"
            expires_at = datetime.now() + timedelta(hours=DEAL_EXPIRE_HOURS)
            
            cursor = self.conn.cursor()
            cursor.execute('''
                INSERT INTO deals 
                (id, seller_id, seller_username, amount, currency, payment_method, payment_data, expires_at)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            ''', (deal_id, seller_id, seller_username, amount, currency, payment_method, payment_data, expires_at.isoformat()))
            self.conn.commit()
            print(f"✅ Создана сделка {deal_id}")
            return deal_id
        except Exception as e:
            print(f"❌ Ошибка создания сделки: {e}")
            return None
    
    def get_deal(self, deal_id):
        try:
            cursor = self.conn.cursor()
            cursor.execute("SELECT * FROM deals WHERE id = ?", (deal_id,))
            row = cursor.fetchone()
            if row:
                # Получаем информацию о колонках
                cursor.execute("PRAGMA table_info(deals)")
                columns_info = cursor.fetchall()
                columns = [col[1] for col in columns_info]
                
                # Создаем словарь с безопасным доступом к данным
                result = {
                    'id': row[0], 
                    'seller_id': row[1], 
                    'seller_username': row[2],
                    'buyer_id': row[3] if len(row) > 3 else None, 
                    'buyer_username': row[4] if len(row) > 4 else None, 
                    'amount': row[5] if len(row) > 5 else 0,
                    'currency': row[6] if len(row) > 6 else 'RUB', 
                    'payment_method': row[7] if len(row) > 7 else '', 
                    'payment_data': row[8] if len(row) > 8 else '',
                    'status': row[9] if len(row) > 9 else 'created'
                }
                
                # Добавляем опциональные поля если они есть
                if 'nft_sent' in columns:
                    result['nft_sent'] = bool(row[columns.index('nft_sent')]) if len(row) > columns.index('nft_sent') else False
                else:
                    result['nft_sent'] = False
                    
                if 'admin_check' in columns:
                    result['admin_check'] = bool(row[columns.index('admin_check')]) if len(row) > columns.index('admin_check') else False
                else:
                    result['admin_check'] = False
                    
                if 'check_requested' in columns:
                    result['check_requested'] = bool(row[columns.index('check_requested')]) if len(row) > columns.index('check_requested') else False
                else:
                    result['check_requested'] = False
                    
                result['created_at'] = row[columns.index('created_at')] if 'created_at' in columns and len(row) > columns.index('created_at') else None
                result['expires_at'] = row[columns.index('expires_at')] if 'expires_at' in columns and len(row) > columns.index('expires_at') else None
                result['completed_at'] = row[columns.index('completed_at')] if 'completed_at' in columns and len(row) > columns.index('completed_at') else None
                
                return result
            return None
        except Exception as e:
            print(f"❌ Ошибка получения сделки {deal_id}: {e}")
            return None
    
    def update_deal(self, deal_id, **kwargs):
        try:
            cursor = self.conn.cursor()
            set_clause = ", ".join([f"{k} = ?" for k in kwargs.keys()])
            values = list(kwargs.values())
            values.append(deal_id)
            cursor.execute(f"UPDATE deals SET {set_clause} WHERE id = ?", values)
            self.conn.commit()
            print(f"✅ Обновлена сделка {deal_id}: {kwargs}")
            return True
        except Exception as e:
            print(f"❌ Ошибка обновления сделки {deal_id}: {e}")
            return False
    
